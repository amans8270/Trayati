generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum ReviewStatus {
  PENDING
  PUBLISHED
  REJECTED
}

enum ExperienceTag {
  FAMILY
  SOLO
  COUPLE
  BUSINESS
  PILGRIMAGE
}

enum UserRole {
  GUEST
  ADMIN
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String?        @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          UserRole       @default(GUEST)
  accounts      Account[]
  sessions      Session[]
  bookings      Booking[]      @relation("UserBookings")
  reviews       Review[]
  experiences   Experience[]
  comments      Comment[]
  helpfulVotes  HelpfulVote[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Property {
  id          String       @id @default(cuid())
  slug        String       @unique
  name        String
  description String       @db.Text
  location    String
  price       Float
  maxGuests   Int
  images      String[]
  amenities   String[]
  bookings    Booking[]
  reviews     Review[]
  experiences Experience[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Booking {
  id          String        @id @default(cuid())
  propertyId  String
  guestId     String
  checkIn     DateTime
  checkOut    DateTime
  totalAmount Float
  guests      Int           @default(1)
  status      BookingStatus
  paymentId   String?
  review      Review?
  createdAt   DateTime      @default(now())
  property    Property      @relation(fields: [propertyId], references: [id])
  guest       User          @relation("UserBookings", fields: [guestId], references: [id])
}

model Review {
  id                 String       @id @default(cuid())
  propertyId         String
  authorId           String
  bookingId          String?      @unique
  title              String
  body               String       @db.Text
  overallRating      Int
  cleanlinessRating  Int
  locationRating     Int
  hospitalityRating  Int
  valueRating        Int
  photos             String[]
  helpfulVotes       Int          @default(0)
  status             ReviewStatus
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  property           Property     @relation(fields: [propertyId], references: [id])
  author             User         @relation(fields: [authorId], references: [id])
  booking            Booking?     @relation(fields: [bookingId], references: [id])
  votes              HelpfulVote[]
}

model Experience {
  id          String          @id @default(cuid())
  propertyId  String?
  authorId    String
  title       String
  slug        String          @unique
  body        String          @db.Text
  excerpt     String
  coverMedia  String
  gallery     String[]
  rating      Int
  tags        ExperienceTag[]
  likes       Int             @default(0)
  status      ReviewStatus
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  property    Property?       @relation(fields: [propertyId], references: [id])
  author      User            @relation(fields: [authorId], references: [id])
  comments    Comment[]
}

model Comment {
  id           String     @id @default(cuid())
  experienceId String
  authorId     String
  body         String
  createdAt    DateTime   @default(now())
  experience   Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  author       User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model HelpfulVote {
  id       String @id @default(cuid())
  reviewId String
  userId   String
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([reviewId, userId])
}
